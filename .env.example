# TrendPulse Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Add these if you want to store API keys as environment variables
# (Not recommended - better to use Supabase Edge Functions for production)
# VITE_EXA_API_KEY=your_exa_key
# VITE_RAPID_API_KEY=your_rapidapi_key
# VITE_REDDIT_CLIENT_ID=your_reddit_id
# VITE_REDDIT_CLIENT_SECRET=your_reddit_secret
# VITE_OPENAI_API_KEY=your_openai_key
# VITE_ANTHROPIC_API_KEY=your_anthropic_key
